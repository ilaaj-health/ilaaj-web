{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ilaaj.ai" }],
      "destination": "https://www.ilaaj.ai/$1",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "PK" }],
      "missing": [{ "type": "cookie", "key": "ilaaj-lang-manual" }],
      "destination": "/pk",
      "permanent": false
    },
    {
      "source": "/:path((?!pk|ur|_astro|_vercel|api|assets|favicon|apple-touch-icon|Icon-192|manifest|robots|sitemap|llms).+)",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "PK" }],
      "missing": [{ "type": "cookie", "key": "ilaaj-lang-manual" }],
      "destination": "/pk/:path",
      "permanent": false
    },
    { "source": "/:path+/", "destination": "/:path", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/privacy-policy.html", "destination": "/privacy-policy", "permanent": true },
    { "source": "/terms-and-conditions.html", "destination": "/terms-and-conditions", "permanent": true },
    { "source": "/support.html", "destination": "/support", "permanent": true },
    { "source": "/doctors.html", "destination": "/doctors", "permanent": true },
    { "source": "/faq.html", "destination": "/faq", "permanent": true },
    { "source": "/blog/:slug.html", "destination": "/blog/:slug", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://connect.facebook.net https://us.i.posthog.com https://us-assets.i.posthog.com https://browser.sentry-cdn.com https://js.sentry-cdn.com https://www.clarity.ms https://scripts.clarity.ms https://embed.tawk.to https://va.tawk.to https://static-v.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://embed.tawk.to https://static-v.tawk.to; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://us.i.posthog.com https://us-assets.i.posthog.com https://ingest.sentry.io https://*.ingest.us.sentry.io https://browser.sentry-cdn.com https://js.sentry-cdn.com https://www.google-analytics.com https://region1.google-analytics.com https://connect.facebook.net https://www.facebook.com https://graph.facebook.com https://*.ecs.us-east-1.on.aws https://*.us-central1.run.app https://www.clarity.ms https://*.clarity.ms https://api.tawk.to https://embed.tawk.to https://va.tawk.to https://*.tawk.to wss://ss.tawk.to wss://*.tawk.to; frame-src https://www.googletagmanager.com https://embed.tawk.to https://va.tawk.to; worker-src blob:;" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/(blog|doctors|faq|support|privacy-policy|terms-and-conditions|ur)(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
