---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/blog-posts';

const today = new Date().toISOString().split('T')[0];
const visiblePosts = posts.filter(p => !p.scheduled || p.scheduled <= today);
const collectionSchema = { "@context": "https://schema.org", "@type": "CollectionPage", "name": "Ilaaj AI Health Blog", "url": "https://www.ilaaj.ai/blog", "description": "Expert health articles in Urdu & English for Pakistanis", "publisher": { "@type": "Organization", "name": "Ilaaj AI", "url": "https://www.ilaaj.ai" }, "itemListElement": visiblePosts.map((p, i) => ({ "@type": "ListItem", "position": i + 1, "name": p.title, "url": `https://www.ilaaj.ai/blog/${p.slug}` })) };
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.ilaaj.ai/" }, { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.ilaaj.ai/blog" }] };

const arrowSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`;
---

<BaseLayout
  title="Health Blog — AI Health Tips & Medical Advice | Ilaaj AI"
  description="Read expert health articles in Urdu & English. AI health tips, medical advice, and wellness guides tailored for Pakistanis — by Ilaaj AI."
  canonical="https://www.ilaaj.ai/blog"
  keywords="health blog Pakistan, medical articles Urdu, health tips Pakistan, healthcare guide Pakistan, Roman Urdu health tips, online health resources Pakistan, medical advice blog, AI health content Urdu"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  </Fragment>
  <main>
    <section class="blog-hero">
      <div class="container">
        <div class="blog-hero__content">
          <span class="section-header__tag">Ilaaj AI Blog</span>
          <h1 class="blog-hero__title">Health &amp; Wellness Articles</h1>
          <p class="blog-hero__subtitle">Expert health tips, medical advice, and wellness articles to help you live a healthier life &mdash; in any language you prefer.</p>
        </div>
      </div>
    </section>

    <section class="blog-grid-section">
      <div class="container">
        <div class="blog-grid">
          {posts.map(post => {
            const isHidden = post.scheduled && post.scheduled > today;
            return (
              <div data-scheduled={post.scheduled} hidden={isHidden || undefined}>
                <a href={`/blog/${post.slug}`} class="blog-card">
                  <div class="blog-card__image">
                    <img src={post.img} alt={post.alt} loading="lazy" width="400" height="250" />
                  </div>
                  <div class="blog-card__body">
                    <span class="blog-card__date">{post.date}</span>
                    <h2 class="blog-card__title">{post.title}</h2>
                    <p class="blog-card__excerpt">{post.excerpt}</p>
                    <span class="blog-card__read-more">
                      Read Article
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="blog-cta">
      <div class="container">
        <div class="blog-cta__card">
          <h2 class="blog-cta__title">Need Health Advice Right Now?</h2>
          <p class="blog-cta__desc">Chat with our AI health assistant in any language. Get doctor-verified prescriptions at affordable rates.</p>
          <a href="https://app.ilaaj.ai/chat" class="btn btn--hero-primary btn--lg">
            Try Ilaaj AI Now
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Reveal any posts whose scheduled date has now passed (for cached/stale builds)
  const today = new Date().toISOString().split('T')[0];
  document.querySelectorAll<HTMLElement>('[data-scheduled]').forEach(el => {
    const d = el.dataset.scheduled;
    if (d && d <= today) el.removeAttribute('hidden');
  });
</script>

<style>
  /* Pull in blog-specific styles */
  @import '../../../css/blog.css';
</style>
