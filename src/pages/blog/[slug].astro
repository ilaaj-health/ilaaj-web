---
import { posts } from '../../data/blog-posts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;

function readArticle(file: string, normalize: (s: string) => string) {
  const raw = fs.readFileSync(file, 'utf-8');
  const s = raw.indexOf('<article');
  const e = raw.lastIndexOf('</article>');
  if (s < 0 || e <= s) return null;
  return { html: normalize(raw.slice(raw.indexOf('>', s) + 1, e)), raw };
}

let articleHtml = '';
let hasEnVersion = false;
let sourceRaw = '';
try {
  const r = readArticle(
    path.join(process.cwd(), 'blog', 'en', `${post.slug}.html`),
    h => h.replace(/href="\.\.\/blog\.html"/g, 'href="/blog"')
          .replace(/href="\.\.\/\.\.\/blog\.html"/g, 'href="/blog"')
  );
  if (r) { articleHtml = r.html; sourceRaw = r.raw; hasEnVersion = true; }
} catch {}

if (!hasEnVersion) {
  try {
    const r = readArticle(
      path.join(process.cwd(), 'blog', `${post.slug}.html`),
      h => h.replace(/href="\.\.\/blog\.html"/g, 'href="/blog"')
    );
    if (r) { articleHtml = r.html; sourceRaw = r.raw; }
  } catch {}
}

// Restore the hand-authored JSON-LD (MedicalWebPage, BreadcrumbList, FAQPage)
// from the source <head> — the article-only extraction above otherwise drops it.
const jsonLd = (sourceRaw.match(/<script type="application\/ld\+json">[\s\S]*?<\/script>/g) || []).join('\n');
---

<BaseLayout
  lang="en"
  title={`${hasEnVersion && post.enTitle ? post.enTitle : post.title} | Ilaaj AI`}
  description={hasEnVersion && post.enExcerpt ? post.enExcerpt : post.excerpt}
  canonical={hasEnVersion ? `https://www.ilaaj.ai/blog/${post.slug}` : `https://www.ilaaj.ai/pk/blog/${post.slug}`}
  noindex={!hasEnVersion}
  ogImage={post.img}
>
  {jsonLd && <Fragment slot="head" set:html={jsonLd} />}
  <main>
    {articleHtml
      ? <article class="blog-post" set:html={articleHtml} />
      : <article class="blog-post">
          <div class="container">
            <a href="/blog" class="blog-post__back">← Back to Blog</a>
            <h1 class="blog-post__title">{post.title}</h1>
            <div class="blog-post__content"><p>{post.excerpt}</p></div>
            <a href="https://app.ilaaj.ai/chat" class="btn btn--primary">Get Advice from AI →</a>
          </div>
        </article>
    }
  </main>
</BaseLayout>

<style is:global>
  @import '../../../css/blog.css';
</style>
