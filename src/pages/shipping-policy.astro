---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/legal.css';
---

<BaseLayout
  lang="en"
  title="Shipping &amp; Delivery Policy | Ilaaj AI"
  description="Ilaaj AI delivers all healthcare services digitally. Learn how and when our consultations and prescriptions are delivered."
  canonical="https://www.ilaaj.ai/shipping-policy"
  keywords="ilaaj AI shipping policy, digital delivery Pakistan, telemedicine delivery policy"
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h1 class="legal-hero__title">Shipping &amp; Delivery Policy</h1>
        <p class="legal-hero__meta">Last updated: June 4, 2026</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">
          <div class="legal-section">
            <h2>Digital Delivery Only</h2>
            <p>Ilaaj AI is a digital telemedicine platform. All services — AI-assisted consultations and doctor-verified prescriptions — are delivered electronically within the Ilaaj AI app and via email. We do not ship any physical products.</p>
          </div>
          <div class="legal-section">
            <h2>Delivery Timeline</h2>
            <p>AI consultation responses are available instantly. Doctor-verified prescriptions are typically delivered within <strong>15–20 minutes</strong> during operational hours and are accessible directly in your account.</p>
          </div>
          <div class="legal-section">
            <h2>Shipping Charges</h2>
            <p>As no physical goods are shipped, there are <strong>no shipping or delivery charges</strong> of any kind.</p>
          </div>
          <div class="legal-section">
            <h2>Delivery Issues</h2>
            <p>If you do not receive your prescription or consultation result within the expected time, please contact us so we can resolve it promptly.</p>
          </div>
          <div class="legal-section legal-section--highlight legal-contact">
            <h2>Contact Us</h2>
            <p><strong>Email:</strong> <a href="mailto:hello@ilaaj.ai">hello@ilaaj.ai</a></p>
            <p><strong>Phone:</strong> +92-324-819-9663 (Mon–Fri, 9AM–6PM PKT)</p>
            <p><strong>Address:</strong> Office 7, Plot 782, Block G4, Phase 2, Johar Town, Lahore, 54782, Pakistan</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
