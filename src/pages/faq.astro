---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/faq.css';
import { catsEn as cats, sectionsEn as sections } from '../data/faq-en';
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": sections.flatMap(s => s.items.map(item => ({ "@type": "Question", "name": item.q, "acceptedAnswer": { "@type": "Answer", "text": item.a } }))) };
---
<BaseLayout
  lang="en"
  title="Ilaaj AI FAQ | Online Doctor & Prescription Help — Pakistan"
  description="Answers about Ilaaj AI (ailaaj): how the online AI doctor works, consultation cost in PKR, valid online prescriptions, PMDC-verified doctors, privacy, and cities served across Pakistan."
  canonical="https://www.ilaaj.ai/faq"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  </Fragment>
<main>
<section class="faq-hero">
  <div class="container">
    <span class="section-header__tag faq-hero__tag">Help Center</span>
    <h1>How can we assist your health journey today?</h1>
    <p>Answers to common questions about Ilaaj AI — Pakistan's online AI doctor. Learn how the AI works, what a consultation costs, how <a href="/doctors">PMDC-verified doctors</a> issue a valid online prescription, and how to <a href="https://app.ilaaj.ai/chat">start a chat</a>.</p>
    <div class="faq-search">
      <input id="faqSearch" type="text" placeholder="Search for help…" />
      <div class="faq-search__tags"><span>Popular:</span><a href="#security">PMDC Verification</a><a href="#prescription">Prescription Delivery</a><a href="#medical">Lab Tests</a></div>
    </div>
  </div>
</section>
<section class="faq-body">
<div class="container"><div class="faq-layout">
  <aside class="faq-sidebar">
    <p class="faq-sidebar__label">Support Categories</p>
    <nav>{cats.map(c => <a class="faq-cat" href={`#${c.id}`}>{c.label}</a>)}</nav>
    <div class="faq-contact">
      <h4>Still need help?</h4>
      <p>Our 24/7 medical support team is ready to assist you.</p>
      <a href="https://wa.me/923248199663" target="_blank" rel="noopener" class="btn btn--primary btn--sm">WhatsApp</a>
      <a href="mailto:support@ilaaj.ai" class="btn btn--outline btn--sm">Email Us</a>
    </div>
    <p class="faq-sidebar__label">Popular Pages</p>
    <nav>
      <a class="faq-cat" href="/doctors">Our PMDC Doctors</a>
      <a class="faq-cat" href="/blog">Health Blog</a>
      <a class="faq-cat" href="/pricing">Pricing</a>
    </nav>
  </aside>
  <div class="faq-content">
    {sections.map(s => (
      <div class="faq-section" id={s.id}>
        <h2>{s.title}</h2>
        {s.items.map(item => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    ))}
    <div class="faq-banner">
      <h3>Trusted by 500k+ Patients</h3>
      <p>AI algorithms trained on diverse medical data ensuring accuracy for the Pakistani demographic.</p>
    </div>
    <div class="faq-bento">
      <div class="faq-bento__card faq-bento__card--primary">
        <h4>Doctor Portal</h4>
        <p>Are you a healthcare professional? Join Pakistan's fastest-growing digital clinic.</p>
        <a href="https://wa.me/923248199663?text=Hi%2C%20I%27m%20a%20healthcare%20professional%20interested%20in%20joining%20Ilaaj%20AI%20as%20a%20doctor." target="_blank" rel="noopener" class="btn btn--white btn--sm">Partner With Us</a>
      </div>
      <div class="faq-bento__card">
        <h4>Mobile App</h4>
        <p>Manage your health on the go. Get instant alerts and health tracking.</p>
        <div class="faq-bento__apps"><span class="btn btn--primary btn--sm">App Store</span><span class="btn btn--primary btn--sm">Play Store</span></div>
      </div>
    </div>
  </div>
</div></div>
</section>
</main>
</BaseLayout>
<script>
  document.querySelectorAll('.faq-cat').forEach(l => l.addEventListener('click', () => { document.querySelectorAll('.faq-cat').forEach(x => x.classList.remove('active')); l.classList.add('active'); }));
  const s = document.getElementById('faqSearch') as HTMLInputElement | null;
  s?.addEventListener('input', () => { const q = s.value.trim().toLowerCase(); document.querySelectorAll<HTMLElement>('.faq-item').forEach(el => { el.style.display = (!q || el.textContent!.toLowerCase().includes(q)) ? '' : 'none'; }); });
</script>
