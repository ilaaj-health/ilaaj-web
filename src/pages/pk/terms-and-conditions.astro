---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/legal.css';
---

<BaseLayout
  lang="pk"
  title="Terms and Conditions | Ilaaj AI"
  description="Read the terms and conditions for using Ilaaj AI's health consultation platform."
  canonical="https://www.ilaaj.ai/pk/terms-and-conditions"
  keywords="ilaaj AI terms of service, telemedicine terms Pakistan, health platform conditions, ilaaj AI user agreement, online doctor terms"
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <h1 class="legal-hero__title">Terms and Conditions</h1>
        <p class="legal-hero__meta">Last updated: April 8, 2026</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">
          <div class="legal-section legal-section--warning">
            <div class="warning-box">
              <svg class="warning-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <div>
                <h3>Important Medical Disclaimer</h3>
                <p>Ilaaj AI is not a substitute for professional medical care. Always consult qualified healthcare professionals for medical diagnosis and treatment. In emergencies, call 1122 immediately.</p>
              </div>
            </div>
          </div>
          <div class="legal-section">
            <h2>Acceptance of Terms</h2>
            <p>By accessing and using Ilaaj AI, you accept and agree to be bound by these Terms and Conditions. If you do not agree, you must not use our service.</p>
          </div>
          <div class="legal-section">
            <h2>Service Description</h2>
            <p>Ilaaj AI provides AI-powered health consultation services and general health information. Our service provides preliminary guidance and is not a replacement for professional medical care.</p>
          </div>
          <div class="legal-section">
            <h2>User Responsibilities</h2>
            <p>When using Ilaaj AI, you agree to:</p>
            <ul>
              <li>Provide accurate information</li>
              <li>Use the service responsibly and lawfully</li>
              <li>Not misuse or abuse the service</li>
              <li>Consult healthcare professionals for medical decisions</li>
            </ul>
          </div>
          <div class="legal-section">
            <h2>Limitation of Liability</h2>
            <p>Ilaaj AI is provided "as is" without warranties. We are not liable for any decisions made based on information provided through our service. Always consult qualified healthcare professionals for medical advice.</p>
          </div>
          <div class="legal-section">
            <h2>Changes to Terms</h2>
            <p>We reserve the right to modify these Terms at any time. Changes are effective immediately upon posting. Continued use constitutes acceptance of modified terms.</p>
          </div>
          <div class="legal-section legal-section--highlight legal-contact">
            <h2>Contact Information</h2>
            <p><strong>Email:</strong> <a href="mailto:support@ilaaj.ai">support@ilaaj.ai</a></p>
            <p><strong>Phone:</strong> +92-324-819-9663</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
