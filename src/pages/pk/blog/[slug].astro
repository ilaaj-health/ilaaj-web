---
import { posts } from '../../../data/blog-posts';
import { fixBlogLinks } from '../../../data/fix-blog-links';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;

let articleHtml = '';
try {
  const raw = fs.readFileSync(
    path.join(process.cwd(), 'blog', `${post.slug}.html`), 'utf-8'
  );
  const s = raw.indexOf('<article');
  const e = raw.lastIndexOf('</article>');
  if (s >= 0 && e > s) {
    articleHtml = fixBlogLinks(raw.slice(raw.indexOf('>', s) + 1, e), '/pk')
      .replace(/src="\.\.\/assets\//g, 'src="/assets/')
      .replace(/href="\.\.\/assets\//g, 'href="/assets/');
  }
} catch {}

const pubDate = new Date(post.scheduled ?? post.date).toISOString().split('T')[0];
const postUrl = `https://www.ilaaj.ai/pk/blog/${post.slug}`;
const postKeywords = `${post.title}, ${post.slug.replace(/-/g, ' ')}, health Pakistan, medical advice Pakistan, Ilaaj AI`;
const blogSchema = { "@context": "https://schema.org", "@type": "BlogPosting", "headline": post.title, "description": post.excerpt, "image": post.img, "url": postUrl, "datePublished": pubDate, "dateModified": pubDate, "author": { "@type": "Organization", "name": "Ilaaj AI", "url": "https://www.ilaaj.ai" }, "publisher": { "@type": "Organization", "name": "Ilaaj AI", "url": "https://www.ilaaj.ai", "logo": { "@type": "ImageObject", "url": "https://www.ilaaj.ai/assets/Icon-192.png" } }, "mainEntityOfPage": { "@type": "WebPage", "@id": postUrl } };
const crumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.ilaaj.ai/" }, { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.ilaaj.ai/blog" }, { "@type": "ListItem", "position": 3, "name": post.title, "item": postUrl }] };
const medicalPageSchema = { "@context": "https://schema.org", "@type": "MedicalWebPage", "name": post.title, "description": post.excerpt, "url": postUrl, "inLanguage": "en-PK", "reviewedBy": { "@type": "Organization", "name": "Ilaaj AI", "@id": "https://www.ilaaj.ai/#organization" }, "medicalAudience": { "@type": "MedicalAudience", "audienceType": "Patient" } };
---

<BaseLayout
  lang="pk"
  title={`${post.title} | Ilaaj AI`}
  description={post.excerpt}
  canonical={postUrl}
  keywords={postKeywords}
  ogImage={post.img}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDate} />
    <meta property="article:author" content="Ilaaj AI" />
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(crumbSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(medicalPageSchema)}></script>
  </Fragment>
  <main>
    {articleHtml
      ? <article class="blog-post" set:html={articleHtml} />
      : <article class="blog-post">
          <div class="container">
            <a href="/pk/blog" class="blog-post__back">← Back to Blog</a>
            <h1 class="blog-post__title">{post.title}</h1>
            <div class="blog-post__content"><p>{post.excerpt}</p></div>
            <a href="https://app.ilaaj.ai/chat" class="btn btn--primary">Get Advice from AI →</a>
          </div>
        </article>
    }
  </main>
</BaseLayout>

<style is:global>
  @import '../../../../css/blog.css';
</style>
