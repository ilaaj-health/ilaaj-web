---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DoctorsList from '../../components/home/DoctorsList.astro';
import { doctors } from '../../data/doctors';

const physicianSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Ilaaj AI PMDC-Verified Doctors",
  "url": "https://www.ilaaj.ai/pk/doctors",
  "itemListElement": doctors.map((d, i) => ({
    "@type": "ListItem", "position": i + 1, "url": `https://www.ilaaj.ai/pk/doctors/${d.slug}`,
    "item": { "@type": "Physician", "name": d.name, "medicalSpecialty": d.spec, "hasCredential": d.qual, "url": `https://www.ilaaj.ai/pk/doctors/${d.slug}`, "worksFor": { "@id": "https://www.ilaaj.ai/#organization" } }
  }))
};
---

<BaseLayout
  lang="pk"
  title="Our Verified Doctors | PMDC-Registered Physicians — Ilaaj AI Pakistan"
  description="Meet 13+ PMDC-registered doctors who verify every prescription on Ilaaj AI. GPs, gynaecologists, dermatologists across Pakistan."
  canonical="https://www.ilaaj.ai/pk/doctors"
  keywords="PMDC verified doctors Pakistan, online doctor consultation Pakistan, specialist doctors online, doctor finder Pakistan, gynaecologist online Pakistan, dermatologist online Pakistan, PMDC registered physician, telemedicine doctors Pakistan, book doctor online Pakistan, GP online Pakistan"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(physicianSchema)}></script>
  </Fragment>
  <main>
    <section class="doctors-hero">
      <div class="container">
        <div class="doctors-hero__content">
          <span class="section-header__tag">PMDC Verified</span>
          <h1>Our Verified Doctors</h1>
          <p class="doctors-hero__desc">Every prescription on Ilaaj AI is reviewed and approved by a licensed, PMDC-registered doctor. No AI-only prescriptions — ever.</p>
        </div>
      </div>
    </section>

    <DoctorsList lang="pk" />

    <section class="cta">
      <div class="container">
        <div class="cta__card reveal">
          <div class="cta__card-content">
            <h2 class="cta__title">Get Doctor-Verified Health Advice</h2>
            <p>Chat with our AI, get your symptoms assessed, and receive a doctor-verified prescription in 15-20 minutes.</p>
            <a href="https://app.ilaaj.ai/chat" class="btn btn--hero-primary btn--lg">
              Start Consultation
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
