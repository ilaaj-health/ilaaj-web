---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import HowItWorks from '../../components/home/HowItWorks.astro';
import Features from '../../components/home/Features.astro';
import Comparison from '../../components/home/Comparison.astro';
import DoctorsPreview from '../../components/home/DoctorsPreview.astro';

const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
  { "@type": "Question", "name": "How much does Ilaaj AI cost?", "acceptedAnswer": { "@type": "Answer", "text": "Doctor-verified consultations are paid and priced in Pakistani Rupees (PKR). Fees vary by doctor and specialty, typically PKR 200 to PKR 1,500 per consultation, with prescription verification included. The exact fee is always shown before you confirm and pay. No hidden fees." }},
  { "@type": "Question", "name": "How does the doctor verification work?", "acceptedAnswer": { "@type": "Answer", "text": "After the AI collects your symptoms, a licensed doctor reviews the full session transcript and approves the prescription with their name on it." }},
  { "@type": "Question", "name": "What languages can I chat in?", "acceptedAnswer": { "@type": "Answer", "text": "Urdu, English, Roman Urdu, Hindi, Arabic, or any language. We have native Nastaliq RTL support and voice message support." }},
  { "@type": "Question", "name": "What should I do in an emergency?", "acceptedAnswer": { "@type": "Answer", "text": "For serious emergencies, call 1122 (Rescue) or go to the nearest hospital. Ilaaj AI is for general consultations, not emergencies." }}
]};
const orgSchema = { "@context": "https://schema.org", "@type": "MedicalOrganization", "@id": "https://www.ilaaj.ai/#organization", "name": "Ilaaj AI", "url": "https://www.ilaaj.ai", "logo": { "@type": "ImageObject", "url": "https://www.ilaaj.ai/assets/Icon-192.png", "width": 192, "height": 192 }, "description": "Pakistan's first AI-powered telemedicine platform offering doctor-verified prescriptions in Urdu and English.", "email": "support@ilaaj.ai", "address": { "@type": "PostalAddress", "streetAddress": "Office 7, Plot 782, Block G4, Phase 2, Johar Town", "addressLocality": "Lahore", "postalCode": "54782", "addressCountry": "PK" }, "contactPoint": { "@type": "ContactPoint", "telephone": "+92-324-819-9663", "contactType": "customer support", "availableLanguage": ["English", "Urdu"] }, "sameAs": ["https://www.instagram.com/ilaaj_ai/", "https://www.facebook.com/profile.php?id=61588590745625", "https://x.com/ilaajai"], "areaServed": { "@type": "Country", "name": "Pakistan" } };
const siteSchema = { "@context": "https://schema.org", "@type": "WebSite", "@id": "https://www.ilaaj.ai/#website", "name": "Ilaaj AI", "url": "https://www.ilaaj.ai", "publisher": { "@id": "https://www.ilaaj.ai/#organization" }, "potentialAction": { "@type": "SearchAction", "target": { "@type": "EntryPoint", "urlTemplate": "https://www.ilaaj.ai/blog?q={search_term_string}" }, "query-input": "required name=search_term_string" } };
---

<BaseLayout
  lang="pk"
  hasUrdu={true}
  title="Ilaaj AI — Pakistan's First AI Health Platform"
  description="Get instant AI medical assessments verified by PMDC-certified doctors. Chat in Urdu or English, get a doctor-verified prescription in 15-20 minutes. Affordable, anonymous, 24/7."
  canonical="https://www.ilaaj.ai/pk"
  keywords="AI doctor Pakistan, online doctor Pakistan, AI health assistant, medical advice Urdu, telemedicine Pakistan, online doctor consultation, AI prescription Pakistan, doctor verified prescription, ilaaj AI, symptom checker Pakistan, medical AI chatbot, family health app Pakistan, digital health Pakistan, online doctor Urdu, health tech Pakistan, doctor advice Pakistan, telehealth Pakistan"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)}></script>
  </Fragment>
  <main>
    <Hero />
    <HowItWorks />
    <Features />
    <Comparison />
    <DoctorsPreview />
  </main>
</BaseLayout>
