---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/legal.css';
---

<BaseLayout
  lang="ur"
  hasUrdu={true}
  title="شپنگ اور ڈیلیوری پالیسی | علاج AI"
  description="علاج AI تمام صحت خدمات ڈیجیٹل طور پر فراہم کرتا ہے۔ جانیں کہ ہماری مشاورت اور نسخے کیسے اور کب فراہم کیے جاتے ہیں۔"
  canonical="https://www.ilaaj.ai/ur/shipping-policy"
  keywords="علاج AI شپنگ پالیسی, ڈیجیٹل ڈیلیوری پاکستان, ٹیلی میڈیسن ڈیلیوری پالیسی"
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h1 class="legal-hero__title">شپنگ اور ڈیلیوری پالیسی</h1>
        <p class="legal-hero__meta">آخری تازہ کاری: 4 جون 2026</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">
          <div class="legal-section">
            <h2>صرف ڈیجیٹل ڈیلیوری</h2>
            <p>علاج AI ایک ڈیجیٹل ٹیلی میڈیسن پلیٹ فارم ہے۔ تمام خدمات — AI کی مدد سے مشاورت اور ڈاکٹر سے تصدیق شدہ نسخے — علاج AI ایپ اور ای میل کے ذریعے الیکٹرانک طور پر فراہم کی جاتی ہیں۔ ہم کوئی جسمانی مصنوعات ارسال نہیں کرتے۔</p>
          </div>
          <div class="legal-section">
            <h2>ڈیلیوری کا وقت</h2>
            <p>AI مشاورت کے جوابات فوری دستیاب ہوتے ہیں۔ ڈاکٹر سے تصدیق شدہ نسخے عام طور پر آپریشنل اوقات کے دوران <strong>15 تا 20 منٹ</strong> میں فراہم کیے جاتے ہیں اور براہ راست آپ کے اکاؤنٹ میں دستیاب ہوتے ہیں۔</p>
          </div>
          <div class="legal-section">
            <h2>شپنگ چارجز</h2>
            <p>چونکہ کوئی جسمانی سامان ارسال نہیں کیا جاتا، اس لیے کسی قسم کے <strong>شپنگ یا ڈیلیوری چارجز نہیں</strong> ہیں۔</p>
          </div>
          <div class="legal-section">
            <h2>ڈیلیوری کے مسائل</h2>
            <p>اگر آپ کو متوقع وقت میں اپنا نسخہ یا مشاورت کا نتیجہ موصول نہ ہو، تو براہ کرم ہم سے رابطہ کریں تاکہ ہم اسے فوری حل کر سکیں۔</p>
          </div>
          <div class="legal-section legal-section--highlight legal-contact">
            <h2>رابطہ کریں</h2>
            <p><strong>ای میل:</strong> <a href="mailto:hello@ilaaj.ai">hello@ilaaj.ai</a></p>
            <p><strong>فون:</strong> ‎+92-324-819-9663 (پیر تا جمعہ، صبح 9 تا شام 6 PKT)</p>
            <p><strong>پتہ:</strong> آفس 7، پلاٹ 782، بلاک G4، فیز 2، جوہر ٹاؤن، لاہور، 54782، پاکستان</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
