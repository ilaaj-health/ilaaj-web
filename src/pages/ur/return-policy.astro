---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/legal.css';
---

<BaseLayout
  lang="ur"
  hasUrdu={true}
  title="ریٹرن پالیسی | علاج AI"
  description="علاج AI ڈیجیٹل صحت خدمات فراہم کرتا ہے۔ جانیں کہ ہماری ڈیجیٹل مشاورت اور نسخوں کے لیے ریٹرن کیسے ہینڈل کیے جاتے ہیں۔"
  canonical="https://www.ilaaj.ai/ur/return-policy"
  keywords="علاج AI ریٹرن پالیسی, ڈیجیٹل سروس ریٹرن پاکستان, ٹیلی میڈیسن ریٹرن پالیسی"
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
        </div>
        <h1 class="legal-hero__title">ریٹرن پالیسی</h1>
        <p class="legal-hero__meta">آخری تازہ کاری: 4 جون 2026</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">
          <div class="legal-section">
            <h2>ڈیجیٹل خدمات</h2>
            <p>علاج AI ڈیجیٹل صحت خدمات فراہم کرتا ہے — AI کی مدد سے مشاورت اور ڈاکٹر سے تصدیق شدہ نسخے جو ہماری ایپ کے ذریعے الیکٹرانک طور پر فراہم کیے جاتے ہیں۔ ہم کوئی جسمانی مصنوعات فروخت یا ارسال نہیں کرتے، اس لیے روایتی پروڈکٹ ریٹرن لاگو نہیں ہوتا۔</p>
          </div>
          <div class="legal-section">
            <h2>منسوخی</h2>
            <p>آپ مشاورت شروع ہونے سے پہلے اسے مفت منسوخ کر سکتے ہیں۔ مشاورت شروع ہونے یا نسخہ جاری ہونے کے بعد، خدمت فراہم شدہ تصور کی جاتی ہے اور واپس نہیں کی جا سکتی۔</p>
          </div>
          <div class="legal-section">
            <h2>خدمت کے مسائل اور رقم کی واپسی</h2>
            <p>اگر کوئی ادا شدہ خدمت فراہم نہ ہو سکی، غلطی سے چارج کی گئی، یا ہماری طرف سے خرابی کے باعث مکمل نہ ہو سکی، تو آپ رقم کی واپسی کے اہل ہو سکتے ہیں۔ مکمل تفصیل کے لیے ہماری <a href="/ur/refund-policy">رقم واپسی کی پالیسی</a> دیکھیں۔</p>
          </div>
          <div class="legal-section">
            <h2>درخواست کیسے کریں</h2>
            <p>اپنے رجسٹرڈ فون نمبر یا ای میل اور لین دین کی تفصیلات کے ساتھ <strong>hello@ilaaj.ai</strong> پر ای میل کریں۔ ہم <strong>3 کاروباری دنوں</strong> میں جواب دیں گے۔</p>
          </div>
          <div class="legal-section legal-section--highlight legal-contact">
            <h2>رابطہ کریں</h2>
            <p><strong>ای میل:</strong> <a href="mailto:hello@ilaaj.ai">hello@ilaaj.ai</a></p>
            <p><strong>فون:</strong> ‎+92-324-819-9663 (پیر تا جمعہ، صبح 9 تا شام 6 PKT)</p>
            <p><strong>پتہ:</strong> آفس 7، پلاٹ 782، بلاک G4، فیز 2، جوہر ٹاؤن، لاہور، 54782، پاکستان</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
