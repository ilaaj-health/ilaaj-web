---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/legal.css';
---

<BaseLayout
  lang="ur"
  hasUrdu={true}
  title="رقم کی واپسی کی پالیسی | علاج AI"
  description="علاج AI کی رقم واپسی کی پالیسی پڑھیں — اہلیت، مدت، اور مشاورت و نسخوں کے لیے رقم واپسی کی درخواست کا طریقہ۔"
  canonical="https://www.ilaaj.ai/ur/refund-policy"
  keywords="علاج AI رقم واپسی پالیسی, ٹیلی میڈیسن رقم واپسی پاکستان, مشاورت رقم واپسی, نسخہ رقم واپسی پالیسی"
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><path d="M3 10h18M3 10l2-5h14l2 5M3 10v9a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-9"/></svg>
        </div>
        <h1 class="legal-hero__title">رقم کی واپسی کی پالیسی</h1>
        <p class="legal-hero__meta">آخری تازہ کاری: 4 جون 2026</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="legal-content">
          <div class="legal-section">
            <h2>جائزہ</h2>
            <p>یہ پالیسی بتاتی ہے کہ آپ علاج AI کے ذریعے خریدی گئی خدمات — بشمول AI مشاورت اور ڈاکٹر سے تصدیق شدہ نسخوں — کے لیے رقم کی واپسی کب اور کیسے طلب کر سکتے ہیں۔</p>
          </div>
          <div class="legal-section">
            <h2>رقم واپسی کی اہلیت</h2>
            <p>آپ رقم واپسی کے اہل ہو سکتے ہیں اگر:</p>
            <ul>
              <li>آپ سے رقم وصول کی گئی لیکن ہماری طرف سے تکنیکی خرابی کے باعث خدمت فراہم نہ ہو سکی۔</li>
              <li>ایک ہی مشاورت کے لیے آپ سے ایک سے زائد بار رقم وصول کی گئی۔</li>
              <li>ڈاکٹر سے تصدیق شدہ نسخہ جاری نہ ہو سکا اور کوئی متبادل خدمت فراہم نہ کی گئی۔</li>
            </ul>
          </div>
          <div class="legal-section">
            <h2>ناقابلِ واپسی صورتیں</h2>
            <ul>
              <li>وہ مشاورتیں جو مکمل ہو چکی ہوں اور نسخہ یا طبی رہنمائی فراہم کی جا چکی ہو۔</li>
              <li>درست اور مکمل طور پر فراہم کی گئی طبی رائے سے عدم اطمینان۔</li>
              <li>اہل مدت گزر جانے کے بعد کی گئی درخواستیں۔</li>
            </ul>
          </div>
          <div class="legal-section">
            <h2>رقم واپسی کی مدت</h2>
            <p>منظور شدہ رقم اصل ادائیگی کے ذریعے <strong>7 تا 14 کاروباری دنوں</strong> میں واپس کی جاتی ہے۔ بینک یا ادائیگی فراہم کنندہ کے عمل میں اضافی دن لگ سکتے ہیں۔</p>
          </div>
          <div class="legal-section">
            <h2>رقم واپسی کی درخواست کا طریقہ</h2>
            <p>اپنے رجسٹرڈ فون نمبر یا ای میل، لین دین کی تاریخ، اور وجہ کے ساتھ <strong>support@ilaaj.ai</strong> پر ای میل کریں۔ ہم <strong>3 کاروباری دنوں</strong> میں جواب دیں گے۔</p>
          </div>
          <div class="legal-section legal-section--highlight legal-contact">
            <h2>رابطہ کریں</h2>
            <p><strong>ای میل:</strong> <a href="mailto:support@ilaaj.ai">support@ilaaj.ai</a></p>
            <p><strong>فون:</strong> ‎+92-324-819-9663 (پیر تا جمعہ، صبح 9 تا شام 6 PKT)</p>
            <p><strong>پتہ:</strong> آفس 7، پلاٹ 782، بلاک G4، فیز 2، جوہر ٹاؤن، لاہور، 54782، پاکستان</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
