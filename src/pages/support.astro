---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/legal.css';
import '../styles/support.css';
---

<BaseLayout
  lang="en"
  title="Support Center | Ilaaj AI — Get Help 24/7"
  description="Need help with Ilaaj AI? Contact our support team via email, phone or live chat. Available 24/7 for technical, billing & account questions."
  canonical="https://www.ilaaj.ai/support"
  noindex={true}
>
  <main>
    <section class="legal-hero">
      <div class="container">
        <div class="legal-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <h1 class="legal-hero__title">Support Center</h1>
        <p class="legal-hero__meta">We're here to help — get in touch anytime.</p>
      </div>
    </section>

    <div class="legal-body">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-card contact-card--email">
            <div class="contact-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3>Email Us</h3>
            <p>Send us an email anytime</p>
            <a href="mailto:support@ilaaj.ai">support@ilaaj.ai</a>
          </div>
          <div class="contact-card contact-card--phone">
            <div class="contact-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3>Call Us</h3>
            <p>Mon-Fri, 9AM-6PM PKT</p>
            <a href="tel:+923248199663">+92-324-819-9663</a>
          </div>
          <div class="contact-card contact-card--chat">
            <div class="contact-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3>Live Chat</h3>
            <p>Chat with us in-app</p>
            <span class="badge">Available 24/7</span>
          </div>
        </div>

        <div class="contact-address">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <p><strong>Registered Office:</strong> Office 7, Plot 782, Block G4, Phase 2, Johar Town, Lahore, 54782, Pakistan</p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
