---
import Analytics from '../components/Analytics.astro';
import SEO from '../components/SEO.astro';
import TailwindConfig from '../components/TailwindConfig.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/utils';
import '../../css/styles.css';
import '../styles/hero.css';
import '../styles/comparison.css';

interface Props {
  lang?: Lang;
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  keywords?: string;
  hasUrdu?: boolean;
}

const {
  lang = 'en',
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/assets/og_ilaaj.png',
  ogType = 'website',
  noindex = false,
  keywords = '',
  hasUrdu = false,
} = Astro.props;

const isRtl = lang === 'ur';
const siteUrl = 'https://www.ilaaj.ai';
const enUrl = canonical.replace(`${siteUrl}/ur`, siteUrl);
const _path = canonical.replace(siteUrl, '').replace(/\/$/, '');
const urUrl = lang === 'ur' ? canonical : `${siteUrl}/ur${_path}`;
---

<!doctype html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <SEO {title} {description} {canonical} {ogImage} {ogType} {noindex} {lang} {enUrl} {urUrl} {keywords} {hasUrdu} />
    <slot name="head" />
    <TailwindConfig />
    <Analytics />
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5XKTHF96" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- <Nav lang={lang} /> -->
    <slot />
    <Footer lang={lang} />
    <script>
      document.documentElement.classList.add('js-ready');
      const revealObserver = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); revealObserver.unobserve(e.target); }});
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    </script>
    <script is:inline>
      (function() {
        window.Tawk_API = window.Tawk_API || {};
        if (window.innerWidth <= 768) {
          window.Tawk_API.onLoad = function() { window.Tawk_API.minimize(); };
          window.Tawk_API.onChatMaximized = function() { window.Tawk_API.minimize(); };
        }
        window.addEventListener('load', function() {
          setTimeout(function() {
            var s1 = document.createElement('script'), s0 = document.getElementsByTagName('script')[0];
            s1.async = true;
            s1.src = 'https://embed.tawk.to/69ce56b0127eae1c37be0e72/1jl70596p';
            s1.charset = 'UTF-8';
            s1.setAttribute('crossorigin', '*');
            s0.parentNode.insertBefore(s1, s0);
          }, 4000);
        });
      })();
    </script>
  </body>
</html>
