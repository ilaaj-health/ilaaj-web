---
import HeroMockup from './HeroMockup.astro';
---

<div class="new-hero-preview">
  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-text">
        <span class="hero-badge">PAKISTAN'S FIRST AI-CLINIC</span>
        <h1 class="hero-title">
          Health Advice, <br /><span class="hero-accent">Aitmaad</span> Ke Saath.
        </h1>
        <p class="hero-desc">
          Get instant AI medical assessments, verified by PMDC-certified doctors. Quality healthcare now accessible from every corner of Pakistan.
        </p>
        <a
          href="https://app.ilaaj.ai/chat"
          class="shimmer-btn"
          style="box-shadow:0 12px 28px -8px rgba(13,148,136,0.55),0 4px 12px -4px rgba(15,118,110,0.35),inset 0 1px 0 rgba(255,255,255,0.18);"
        >
          AI Se Baat Karein — Muft Mashwara
          <span class="hero-cta-icon">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
          </span>
        </a>
      </div>
      <HeroMockup />
    </div>
    <div class="hero-bg-right" aria-hidden="true"></div>
    <div class="hero-bg-bottom" aria-hidden="true"></div>
  </section>
</div>

<style>
.hero-section {
  position: relative; min-height: 85vh;
  display: flex; align-items: center;
  overflow: hidden; background: white;
}
.hero-container {
  width: 100%; max-width: 1280px; margin: 0 auto;
  padding: 3rem 1.5rem;
  display: grid; grid-template-columns: 1fr;
  gap: 4rem; align-items: center;
  position: relative; z-index: 10;
}
@media (min-width: 1024px) {
  .hero-container { grid-template-columns: 1fr 1fr; padding: 3rem; }
}
.hero-text { max-width: 42rem; }
.hero-badge {
  display: inline-block; padding: 0.375rem 1rem;
  border-radius: 9999px; background: #ccfbf1; color: #0f766e;
  font-size: 11px; letter-spacing: 0.1em; font-weight: 700;
  text-transform: uppercase; margin-bottom: 1.5rem;
}
.hero-title {
  font-family: 'Space Grotesk', Inter, system-ui, sans-serif;
  font-size: clamp(2rem, 4.5vw, 3rem);
  line-height: 1.1; letter-spacing: -0.02em; font-weight: 700;
  color: #0f766e; margin-bottom: 1.5rem;
}
.hero-accent { color: #0d9488; }
.hero-desc {
  font-size: 1.125rem; line-height: 1.6; color: #43474f;
  margin-bottom: 2.5rem; max-width: 32rem;
}
.hero-bg-right {
  position: absolute; top: 0; right: 0; width: 33.33%; height: 100%;
  background: linear-gradient(to left, rgba(204,251,241,0.1), transparent);
  pointer-events: none;
}
.hero-bg-bottom {
  position: absolute; bottom: 0; left: 0; width: 100%; height: 8rem;
  background: linear-gradient(to top, #f7f9fb, transparent);
  pointer-events: none;
}
</style>
