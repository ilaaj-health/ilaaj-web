---
import '../../styles/doctors-preview.css';
import { doctors } from '../../data/doctors';
import type { Lang } from '../../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const base = lang === 'pk' ? '/pk/doctors' : '/doctors';
const viewLabel = lang === 'pk' ? 'Profile Dekhein' : 'View Profile';

const specialties = [...new Set(doctors.map(d => d.spec))];
---

<section class="dl-section">
  <div class="container">
    <div class="dl-toolbar">
      <input id="dlSearch" type="text" class="dl-search" placeholder="Search by name or specialty..." autocomplete="off" />
      <div class="dl-filters">
        <button class="dl-filter active" data-spec="all">All Doctors</button>
        {specialties.map(s => <button class="dl-filter" data-spec={s}>{s}</button>)}
      </div>
    </div>
    <div class="dl-grid" id="dlGrid">
      {doctors.map(d => (
        <a href={`${base}/${d.slug}`} class="dp-card dl-card" data-name={d.name.toLowerCase()} data-spec={d.spec}>
          <img src={d.photo} alt={d.name} class="dp-card__photo" width="88" height="88" loading="lazy" />
          <div class="dp-card__name">
              {d.name}
              <svg class="dp-verified" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-label="Verified">
                <circle cx="12" cy="12" r="12" fill="var(--primary-600)"/>
                <path d="M7 12l3 3 7-7" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          <div class="dp-card__spec">{d.spec}</div>
          <div class="dp-card__quals">{d.qual.split(',').map(q=><span class="dp-chip">{q.trim()}</span>)}<span class="dp-chip">{d.exp} Exp.</span></div>
          <span class="dp-card__btn">{viewLabel}</span>
        </a>
      ))}
    </div>
    <div class="dl-empty" id="dlEmpty">No doctors found matching your search.</div>
  </div>
</section>

<script is:inline>
(function(){
  var search=document.getElementById('dlSearch');
  var grid=document.getElementById('dlGrid');
  var empty=document.getElementById('dlEmpty');
  if(!search||!grid)return;
  var cards=Array.from(grid.querySelectorAll('.dl-card'));
  var activeSpec='all';
  function filter(){
    var q=search.value.toLowerCase().trim();
    var visible=0;
    cards.forEach(function(c){
      var show=(activeSpec==='all'||c.dataset.spec===activeSpec)&&(!q||c.dataset.name.includes(q)||c.dataset.spec.toLowerCase().includes(q));
      c.style.display=show?'flex':'none';
      if(show)visible++;
    });
    empty.style.display=visible?'none':'block';
  }
  search.addEventListener('input',filter);
  document.querySelectorAll('.dl-filter').forEach(function(btn){
    btn.addEventListener('click',function(){
      document.querySelectorAll('.dl-filter').forEach(function(b){b.classList.remove('active')});
      this.classList.add('active');
      activeSpec=this.dataset.spec;
      filter();
    });
  });
})();
</script>
