---
import '../../styles/doctors-preview.css';

const doctors = [
  { name:"Dr. M Mujeed ur Rehman", spec:"General Physician", qual:"MBBS, RMP", exp:"5 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1774861881/l2qbg2ewfvhjvg2rmxsl.jpg" },
  { name:"Dr. Maria Mohsin", spec:"General Physician", qual:"MBBS", exp:"4 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1774970468/n6aksbu49oalzyjl4qzg.jpg" },
  { name:"Dr. Sikandar Zulfiqar", spec:"General Physician", qual:"MBBS", exp:"4 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1774955149/edxuypgskvkedpdq5dqd.jpg" },
  { name:"Dr. Tabinda", spec:"General Physician", qual:"MBBS", exp:"4 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1775058269/xetfs13oxme0bkvqpnpj.jpg" },
  { name:"Dr. Wasifa Ahmad", spec:"General Practitioner", qual:"MBBS", exp:"4+ Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1775137767/wrihl0ul6buppj7conzr.jpg" },
  { name:"Dr. Sabeen Fatima Rizvi", spec:"General Practitioner", qual:"MBBS, MCPS", exp:"10+ Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1775648768/e2j611x9q2viow8s6mbt.png" },
  { name:"Dr. Sara Ali Khan", spec:"Gynaecologist", qual:"MBBS, FCPS, MRCOG-1", exp:"10 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1776350887/ged3x1h29plfzzblkrwh.png" },
  { name:"Dr. Saira Zafar", spec:"General Practitioner", qual:"MBBS, MHPE", exp:"10.5 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1776334958/zwpaowaamnt8euxzlkzh.png" },
  { name:"Dr. Umme Aeman Khan", spec:"Dermatologist", qual:"FCPS Derm, SCE UK", exp:"11 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1777285210/hjtt4bqgajqutvxsh783.png" },
  { name:"Dr. Hadia Nadeem", spec:"General Physician", qual:"MBBS (RMP)", exp:"6 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1777026468/djo9viajggkqf2kjkn0j.jpg" },
  { name:"Dr. Muneeb Mubashar", spec:"General Practitioner", qual:"MBBS, MPH", exp:"4 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1776844359/qdfkg95niecs74jtefgm.jpg" },
  { name:"Dr. Ibtasam Ahmad", spec:"General Practitioner", qual:"MBBS, PGR", exp:"7 Yrs", photo:"https://res.cloudinary.com/dpaz2mhy6/image/upload/v1777365610/pbf9ztkeyfytmbtm4dsc.jpg" },
];

const specialties = [...new Set(doctors.map(d => d.spec))];
---

<section class="dl-section">
  <div class="container">
    <div class="dl-toolbar">
      <input id="dlSearch" type="text" class="dl-search" placeholder="Search by name or specialty..." autocomplete="off" />
      <div class="dl-filters">
        <button class="dl-filter active" data-spec="all">All Doctors</button>
        {specialties.map(s => <button class="dl-filter" data-spec={s}>{s}</button>)}
      </div>
    </div>
    <div class="dl-grid" id="dlGrid">
      {doctors.map(d => (
        <div class="dp-card dl-card" data-name={d.name.toLowerCase()} data-spec={d.spec}>
          <img src={d.photo} alt={d.name} class="dp-card__photo" width="88" height="88" loading="lazy" />
          <div class="dp-card__name">{d.name}</div>
          <div class="dp-card__spec">{d.spec}</div>
          <div class="dp-card__quals">{d.qual.split(',').map(q=><span class="dp-chip">{q.trim()}</span>)}<span class="dp-chip">{d.exp} Exp.</span></div>
          <a href="https://app.ilaaj.ai/chat" class="dp-card__btn">Book Appointment</a>
        </div>
      ))}
    </div>
    <div class="dl-empty" id="dlEmpty">No doctors found matching your search.</div>
  </div>
</section>

<script is:inline>
(function(){
  var search=document.getElementById('dlSearch');
  var grid=document.getElementById('dlGrid');
  var empty=document.getElementById('dlEmpty');
  if(!search||!grid)return;
  var cards=Array.from(grid.querySelectorAll('.dl-card'));
  var activeSpec='all';
  function filter(){
    var q=search.value.toLowerCase().trim();
    var visible=0;
    cards.forEach(function(c){
      var show=(activeSpec==='all'||c.dataset.spec===activeSpec)&&(!q||c.dataset.name.includes(q)||c.dataset.spec.toLowerCase().includes(q));
      c.style.display=show?'flex':'none';
      if(show)visible++;
    });
    empty.style.display=visible?'none':'block';
  }
  search.addEventListener('input',filter);
  document.querySelectorAll('.dl-filter').forEach(function(btn){
    btn.addEventListener('click',function(){
      document.querySelectorAll('.dl-filter').forEach(function(b){b.classList.remove('active')});
      this.classList.add('active');
      activeSpec=this.dataset.spec;
      filter();
    });
  });
})();
</script>
