---
import HeroMockup from '../HeroMockup.astro';
---

<div class="new-hero-preview">
  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-text">
        <span class="hero-badge">PAKISTAN'S FIRST AI-CLINIC</span>
        <h1 class="hero-title">
          Health Advice, <br /><span class="hero-accent">You Can</span> Trust.
        </h1>
        <p class="hero-desc">
          Get instant AI medical assessments, verified by PMDC-certified doctors. Quality healthcare now accessible from every corner of Pakistan.
        </p>
        <a
          href="https://app.ilaaj.ai/chat"
          class="shimmer-btn"
          style="box-shadow:0 12px 28px -8px rgba(13,148,136,0.55),0 4px 12px -4px rgba(15,118,110,0.35),inset 0 1px 0 rgba(255,255,255,0.18);"
        >
          Chat with AI — Start Consultation
          <span class="hero-cta-icon">
            <svg class="hero-cta-arrow" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
          </span>
        </a>
      </div>
      <HeroMockup />
    </div>
    <div class="hero-bg-right" aria-hidden="true"></div>
    <div class="hero-bg-bottom" aria-hidden="true"></div>
  </section>
</div>
