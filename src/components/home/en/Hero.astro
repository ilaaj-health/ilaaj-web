---
import HeroMockup from '../HeroMockup.astro';
---

<div class="new-hero-preview">
  <section class="relative min-h-[85vh] flex items-center overflow-hidden bg-white font-body-md text-on-background">
    <div class="container mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center z-10 py-12">

      <div class="max-w-2xl">
        <span class="inline-block px-4 py-1.5 rounded-full bg-secondary-fixed text-on-secondary-fixed text-label-caps mb-6">
          PAKISTAN'S FIRST AI-CLINIC
        </span>
        <h1 class="font-h1 text-h1 text-primary-container mb-6">
          Health Advice, <br /><span class="text-secondary">You Can Trust.</span>
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-lg">
          Get instant AI medical assessments, verified by PMDC-certified doctors. Quality healthcare now accessible from every corner of Pakistan.
        </p>
        <a
          href="https://app.ilaaj.ai/chat"
          class="shimmer-btn group inline-flex items-center justify-center gap-3 px-7 py-3.5 rounded-full text-white font-bold text-base no-underline transition-transform hover:-translate-y-0.5 active:scale-[0.98]"
          style="box-shadow:0 12px 28px -8px rgba(13,148,136,0.55),0 4px 12px -4px rgba(15,118,110,0.35),inset 0 1px 0 rgba(255,255,255,0.18);"
        >
          Chat with AI — Free Consultation
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-white/15 group-hover:bg-white/25 transition-colors">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
          </span>
        </a>
      </div>

      <HeroMockup />
    </div>

    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-secondary-fixed/10 to-transparent pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-background to-transparent pointer-events-none"></div>
  </section>
</div>
