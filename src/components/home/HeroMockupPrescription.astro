---
// State 3: Digital prescription
---
<div class="hero-state hero-state-3 hm-rx">
  <div class="hm-rx-card">
    <div class="hm-rx-head">
      <div class="hm-rx-head-left">
        <div class="hm-rx-icon">
          <span class="material-symbols-outlined">description</span>
        </div>
        <span class="hm-rx-title">Digital Prescription</span>
      </div>
      <span class="hm-rx-id">ID: IL-9920-X</span>
    </div>
    <div class="hm-rx-body">
      <div class="hm-rx-meta">
        <div>
          <p class="hm-rx-label">Patient</p>
          <p class="hm-rx-val">Zain Ahmed</p>
        </div>
        <div>
          <p class="hm-rx-label">Date</p>
          <p class="hm-rx-date">May 24, 2024</p>
        </div>
      </div>
      <div>
        <p class="hm-rx-label" style="margin-bottom:0.5rem">Medication</p>
        <div class="hm-med">
          <div class="hm-med-left">
            <span class="material-symbols-outlined">medication</span>
            <p class="hm-med-name">Panadol CF (500mg)</p>
          </div>
          <span class="hm-med-dose">1-0-1</span>
        </div>
        <div class="hm-med">
          <div class="hm-med-left">
            <span class="material-symbols-outlined">medication</span>
            <p class="hm-med-name">Augmentin (625mg)</p>
          </div>
          <span class="hm-med-dose">1-1-1</span>
        </div>
      </div>
      <div class="hm-rx-foot">
        <div>
          <span class="hm-rx-signed">✓ Digitally Signed</span>
          <p class="hm-rx-sig">Dr. Salman Farooq</p>
        </div>
        <div class="hm-rx-qr">
          <span class="material-symbols-outlined">qr_code_2</span>
        </div>
      </div>
    </div>
  </div>
</div>
