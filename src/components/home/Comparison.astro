---
// Comparison table — styles in src/styles/comparison.css
---

<section class="compare-v2">
  <div class="cv2-inner">
    <div class="cv2-intro">
      <span class="cv2-tag">Competitors Se Moazna</span>
      <h2 class="cv2-title">
        Ilaaj AI <span style="color:#0D9488">vs</span> Baaqi Sab
      </h2>
      <p class="cv2-desc">OlaDoc, Marham aur traditional clinics se seedha moazna karein</p>
    </div>

    <div class="cv2-outer">
      <div class="cv2-table">
        <div class="cv2-h cv2-h--label"><span style="font-size:12px;font-weight:500;color:#94A3B8">Key Features</span></div>
        <div class="cv2-h cv2-h--col"><div class="cv2-h-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="1.8"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21V12h6v9"/></svg></div><div class="cv2-h-name">Traditional Clinic</div></div>
        <div class="cv2-h cv2-h--col"><div class="cv2-h-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="1.8"><rect x="6" y="2" width="12" height="20" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/></svg></div><div class="cv2-h-name">OlaDoc / Marham</div></div>
        <div class="cv2-h cv2-h--us"><span class="cv2-h-badge">Recommended</span><div class="cv2-h-icon cv2-h-icon--us"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.4 1 1.1 1 1.8V18h6v-1.5c0-.7.4-1.4 1-1.8A7 7 0 0 0 12 2z"/></svg></div><div class="cv2-h-name cv2-h-name--us">Ilaaj AI</div></div>

        <div class="cv2-cell cv2-cell--label">Fees</div>
        <div class="cv2-cell cv2-cell--bad"><span class="cv2-dot"></span>PKR 500–3,000</div>
        <div class="cv2-cell cv2-cell--bad"><span class="cv2-dot"></span>PKR 800–3,000</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main">Bilkul Muft</div><div class="cv2-us-sub">FREE FOREVER</div></div>

        <div class="cv2-cell cv2-cell--label">Wait Time</div>
        <div class="cv2-cell cv2-cell--bad"><span class="cv2-dot"></span>1–3 ghante OPD</div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>30 min – 2 hrs</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main">Fori</div><div class="cv2-us-sub">koi intezaar nahin</div></div>

        <div class="cv2-cell cv2-cell--label">Language</div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>Doctor pe depend</div>
        <div class="cv2-cell cv2-cell--bad"><span class="cv2-dot"></span>Sirf English</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main cv2-us-main--inline">Urdu + English + Roman</div></div>

        <div class="cv2-cell cv2-cell--label">Privacy</div>
        <div class="cv2-cell cv2-cell--bad cv2-cell--stack"><div class="cv2-stack-x">×</div><div class="cv2-stack-sub">In-person, koi privacy nahin</div></div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>Profile required</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main cv2-us-main--inline">100% Anonymous</div></div>

        <div class="cv2-cell cv2-cell--label">Availability</div>
        <div class="cv2-cell cv2-cell--bad"><span class="cv2-dot"></span>Clinic hours only</div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>Doctor schedule pe</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main cv2-us-main--inline">24/7 — raat ko bhi</div></div>

        <div class="cv2-cell cv2-cell--label">PMDC Prescription</div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>Kaagaz par</div>
        <div class="cv2-cell cv2-cell--mid"><span class="cv2-tri"></span>Digital (fees ke saath)</div>
        <div class="cv2-cell cv2-cell--us"><div class="cv2-us-main cv2-us-main--inline">PDF — instant delivery</div></div>

        <div class="cv2-cell cv2-cell--label cv2-cell--last">App Download</div>
        <div class="cv2-cell cv2-cell--good cv2-cell--last"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.4" style="margin-right:6px"><polyline points="20 6 9 17 4 12"/></svg>Nahin</div>
        <div class="cv2-cell cv2-cell--bad cv2-cell--last"><span class="cv2-dot"></span>Zaruri hai</div>
        <div class="cv2-cell cv2-cell--us cv2-cell--last"><div class="cv2-us-main cv2-us-main--inline">Nahin — browser se kaam karta hai</div></div>
      </div>
    </div>
  </div>
</section>
