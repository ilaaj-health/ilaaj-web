---
import '../../styles/features.css';
---

<section class="features-v2" id="features">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-header__tag">Built for Pakistan</span>
      <h2 class="section-header__title">Healthcare That Speaks Your Language</h2>
      <p class="section-header__desc">AI-powered patient chat and a professional doctor dashboard — designed for how 220 million Pakistanis actually access care.</p>
    </div>
    <div class="fv2-grid">

      <div class="fv2-card reveal">
        <div class="fv2-icon fv2-icon--teal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
        </div>
        <h3 class="fv2-title">Chat in Any Language</h3>
        <p class="fv2-desc">Urdu, English, Roman Urdu — our AI understands you naturally. Full Nastaliq RTL support and voice messages included.</p>
      </div>

      <div class="fv2-card reveal reveal--delay-1">
        <div class="fv2-icon fv2-icon--blue">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="fv2-title">Guided Symptom Collection</h3>
        <p class="fv2-desc">Our AI asks structured follow-up questions to build a complete picture — like a real doctor's consultation, averaging 3–7 messages per session.</p>
      </div>

      <div class="fv2-card reveal reveal--delay-2">
        <div class="fv2-icon fv2-icon--purple">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="fv2-title">Family Profiles</h3>
        <p class="fv2-desc">Add parents, children, and grandparents — each with their own medical history and consultation records under one account.</p>
      </div>

      <div class="fv2-card reveal">
        <div class="fv2-icon fv2-icon--green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3 class="fv2-title">Real-Time Notifications</h3>
        <p class="fv2-desc">Get instant alerts when your doctor reviews your case and approves your prescription. No waiting rooms, no queues.</p>
      </div>

      <div class="fv2-card reveal reveal--delay-1">
        <div class="fv2-icon fv2-icon--orange">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
        </div>
        <h3 class="fv2-title">PMDC Doctor Verification</h3>
        <p class="fv2-desc">Every doctor is verified against the PMDC registry. A licensed physician reviews your case and signs every prescription.</p>
      </div>

      <div class="fv2-card reveal reveal--delay-2">
        <div class="fv2-icon fv2-icon--pink">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 class="fv2-title">100% Anonymous</h3>
        <p class="fv2-desc">Chat without revealing your name or phone number. Bank-grade AES-256 encryption keeps your medical data completely private.</p>
      </div>

    </div>
  </div>
</section>
