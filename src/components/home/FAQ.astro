---
// FAQ accordion section
const faqs = [
  { q: "How affordable is Ilaaj AI?", a: "Extremely affordable. AI consultation and doctor verification are free (PKR 0) — you only pay for optional medicines or lab tests, with every price clearly shown in Pakistani Rupees (PKR) before payment. No hidden fees, no surprise charges." },
  { q: "How does the doctor verification work?", a: "After the AI collects your symptoms and generates an assessment, your case enters a doctor review queue. A licensed doctor reviews the full session transcript, adds their medical opinion, and approves the prescription — with their name on it." },
  { q: "What languages can I chat in?", a: "You can chat in any language! Urdu, English, Roman Urdu, Hindi, Arabic, or whatever you're comfortable with. Full RTL and Nastaliq script support for Urdu speakers, plus voice message support." },
  { q: "Can I use it for sensitive health topics?", a: "Yes. Ilaaj AI provides a private, anonymous space to discuss sensitive health concerns like reproductive health, mental wellness, and intimate issues — your conversations are encrypted and confidential." },
  { q: "How do I add family members?", a: "Go to your profile and tap 'Add Member'. Create profiles for your children, parents, or any family member — each with their own medical history — then select who you're consulting for when starting a new chat." },
  { q: "What should I do in an emergency?", a: "For serious emergencies, immediately call 1122 (Rescue) or go to the nearest hospital. Ilaaj AI is designed for general health consultations and non-emergency medical guidance." },
];
---

<section class="faq" id="faq">
  <div class="container">
    <div class="faq__layout reveal">
      <div class="faq__header">
        <span class="section-header__tag">FAQ</span>
        <h2 class="faq__title">Common Questions</h2>
        <p class="faq__subtitle">Everything you need to know before getting started with Ilaaj AI.</p>
        <div class="faq__contact-card">
          <div class="faq__contact-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <div><span class="faq__contact-label">Still have questions?</span><a href="mailto:support@ilaaj.ai" class="faq__contact-email">support@ilaaj.ai</a></div>
        </div>
        <div class="faq__contact-card">
          <div class="faq__contact-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
          <div><span class="faq__contact-label">Try it yourself</span><a href="https://app.ilaaj.ai/chat" class="faq__contact-email">Open Ilaaj AI &rarr;</a></div>
        </div>
      </div>

      <div class="faq__list">
        {faqs.map(({ q, a }) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              <span>{q}</span>
              <svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="faq__answer"><p>{a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq__item')!;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__item').forEach(i => {
        i.querySelector('.faq__question')!.setAttribute('aria-expanded', 'false');
        i.classList.remove('faq__item--open');
      });
      if (!isOpen) { btn.setAttribute('aria-expanded', 'true'); item.classList.add('faq__item--open'); }
    });
  });
</script>
