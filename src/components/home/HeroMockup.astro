---
import '../../styles/hero-mockup.css';
import HeroMockupChat from './HeroMockupChat.astro';
import HeroMockupDoctor from './HeroMockupDoctor.astro';
import HeroMockupPrescription from './HeroMockupPrescription.astro';
---

<div class="hm-wrap">
  <div class="hm-progress">
    <div class="progress-bar-fill"></div>
  </div>
  <div class="hm-card">
    <HeroMockupChat />
    <HeroMockupDoctor />
    <HeroMockupPrescription />
    <div class="hm-blur-tr" aria-hidden="true"></div>
    <div class="hm-blur-bl" aria-hidden="true"></div>
  </div>
</div>
