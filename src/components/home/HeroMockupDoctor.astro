---
// State 2: Doctor verification
---
<div class="hero-state hero-state-2 hm-doctor">
  <div class="hm-scan-box">
    <div class="hm-scan-border">
      <div class="scanning-line"></div>
    </div>
    <div class="hm-heartbeat-icon heartbeat-icon">
      <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">medical_services</span>
    </div>
  </div>
  <div class="hm-doctor-info">
    <div class="hm-verify-badge">
      <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">verified</span>
      <span>PMDC Verification</span>
    </div>
    <h3 class="hm-doctor-title">Doctor Reviewing</h3>
    <div class="hm-doctor-card">
      <div class="hm-doctor-avatar">
        <span class="material-symbols-outlined">person</span>
      </div>
      <div>
        <p class="hm-doctor-name">Dr. Salman Farooq</p>
        <p class="hm-doctor-reg">Reg No: #44921-A</p>
      </div>
    </div>
  </div>
</div>
