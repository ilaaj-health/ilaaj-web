---
import { useTranslations, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'pk' } = Astro.props;
const t = useTranslations(lang);
const lp = (p: string) => localePath(p, lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">

      <div class="footer__brand">
        <div class="footer__brand-logo">
          <img src="/assets/ilaaj-logo.jpg" alt="Ilaaj AI" class="footer__logo-img" width="36" height="36" loading="lazy" />
          <span class="footer__logo-text">Ilaaj AI</span>
        </div>
        <p class="footer__brand-desc">{t('footer.tagline')}</p>
        <div class="footer__socials">
          <a href="https://www.instagram.com/ilaaj_ai/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer__social-link">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.974.975 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.975.974-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.974-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608C4.516 2.497 5.783 2.225 7.149 2.163 8.415 2.105 8.795 2.163 12 2.163zm0-2.163C8.741 0 8.332.013 7.052.072 5.197.157 3.355.673 2.014 2.014.673 3.355.157 5.197.072 7.052.013 8.332 0 8.741 0 12c0 3.259.013 3.668.072 4.948.085 1.855.601 3.697 1.942 5.038 1.341 1.341 3.183 1.857 5.038 1.942C8.332 23.987 8.741 24 12 24s3.668-.013 4.948-.072c1.855-.085 3.697-.601 5.038-1.942 1.341-1.341 1.857-3.183 1.942-5.038C23.987 15.668 24 15.259 24 12s-.013-3.668-.072-4.948c-.085-1.855-.601-3.697-1.942-5.038C20.645.673 18.803.157 16.948.072 15.668.013 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324A6.162 6.162 0 0 0 12 5.838zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61588590745625" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer__social-link">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
          </a>
          <a href="https://x.com/ilaajai" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="footer__social-link">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">{t('footer.product')}</h4>
        <ul class="footer__links">
          <li><a href={lp('/#features')}>{t('footer.features')}</a></li>
          <li><a href={lp('/#how-it-works')}>{t('footer.how')}</a></li>
          <li><a href={lp('/#faq')}>{t('footer.faq')}</a></li>
          <li><a href="https://app.ilaaj.ai/chat">{t('footer.app')}</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">{t('footer.legal')}</h4>
        <ul class="footer__links">
          <li><a href={lp('/privacy-policy')}>{t('footer.privacy')}</a></li>
          <li><a href={lp('/terms-and-conditions')}>{t('footer.terms')}</a></li>
          <li><a href={lp('/support')}>{t('footer.support')}</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">{t('footer.contact')}</h4>
        <p class="footer__contact-text">{t('footer.contact.text')}</p>
        <a href="mailto:support@ilaaj.ai" class="footer__email">support@ilaaj.ai</a>
        <p class="footer__emergency">{t('footer.emergency')} <strong>1122</strong> (Rescue)</p>
      </div>

    </div>
    <div class="footer__bottom">
      <p>&copy; {year} Ilaaj AI. {t('footer.rights')}</p>
      <p class="footer__disclaimer">{t('footer.disclaimer')}</p>
    </div>
  </div>
</footer>
