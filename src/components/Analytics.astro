---
// All third-party analytics scripts — loaded lazily after first user interaction
---

<!-- Ad traffic redirect: fbclid/gclid etc → app.ilaaj.ai/chat -->
<script is:inline>
  (function () {
    try {
      var qs = window.location.search;
      if (!qs) return;
      var p = new URLSearchParams(qs);
      var keys = ['fbclid','gclid','gbraid','wbraid','msclkid','ttclid','utm_source','utm_medium','utm_campaign'];
      if (keys.some(function(k){ return p.has(k); })) {
        window.location.replace('https://app.ilaaj.ai/chat' + qs + window.location.hash);
      }
    } catch (e) {}
  })();
</script>

<!-- Sentry: error tracking (lazy) -->
<script is:inline>
  (function() {
    var loaded = false;
    function loadSentry() {
      if (loaded) return; loaded = true;
      window.sentryOnLoad = function() {
        Sentry.init({ tracesSampleRate: 0, replaysSessionSampleRate: 0, replaysOnErrorSampleRate: 0 });
      };
      var s = document.createElement('script');
      s.src = 'https://js.sentry-cdn.com/defa6ca82daea4d4c49a8b69b87c53cc.min.js';
      s.crossOrigin = 'anonymous'; s.async = true;
      document.head.appendChild(s);
    }
    'requestIdleCallback' in window ? requestIdleCallback(loadSentry, { timeout: 4000 }) : setTimeout(loadSentry, 4000);
  })();
</script>

