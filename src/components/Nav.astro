---
import { useTranslations, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'pk' } = Astro.props;
const t = useTranslations(lang);
const lp = (p: string) => localePath(p, lang);
---

<nav class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href={lp('/')} class="navbar__brand">
      <img src="/assets/Icon-192.png" alt="Ilaaj AI" class="navbar__logo" width="36" height="36" fetchpriority="high" decoding="async" />
      <span class="navbar__name">Ilaaj AI</span>
    </a>

    <div class="navbar__center" id="navLinks">
      <a href={lp('/#how-it-works')} class="navbar__link">{t('nav.how')}</a>
      <a href={lp('/#features')} class="navbar__link">{t('nav.features')}</a>
      <a href={lp('/doctors')} class="navbar__link">{t('nav.doctors')}</a>
      <a href={lp('/blog')} class="navbar__link">{t('nav.blog')}</a>
      <a href={lp('/faq')} class="navbar__link">{t('nav.faq')}</a>
    </div>

    <div class="navbar__right">
      <LangSwitch lang={lang} />
      <a href="https://app.ilaaj.ai/chat" class="btn btn--primary btn--sm navbar__cta">
        {t('nav.cta')}
      </a>
    </div>

    <button class="navbar__toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="navbar__mobile" id="mobileMenu">
    <a href={lp('/#how-it-works')} class="navbar__mobile-link">{t('nav.how')}</a>
    <a href={lp('/#features')} class="navbar__mobile-link">{t('nav.features')}</a>
    <a href={lp('/doctors')} class="navbar__mobile-link">{t('nav.doctors')}</a>
    <a href={lp('/blog')} class="navbar__mobile-link">{t('nav.blog')}</a>
    <a href={lp('/faq')} class="navbar__mobile-link">{t('nav.faq')}</a>
    <LangSwitch lang={lang} />
  </div>
</nav>

<script is:inline>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('navbar--scrolled', window.scrollY > 50);
  }, { passive: true });

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('active');
      menu.classList.toggle('active');
    });
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      toggle.classList.remove('active');
      menu.classList.remove('active');
    }));
  }

  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href') || '');
      if (target) { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); history.replaceState(null, '', ' '); }
    });
  });
</script>
