---
import type { Lang } from '../i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = Astro.url.pathname;
const isPk = p.startsWith('/pk');
const isUr = p.startsWith('/ur');
// EN href: strip /pk or /ur prefix
const enHref = isPk ? (p.slice(3) || '/') : isUr ? (p.slice(3) || '/') : p;
// PK href: add /pk prefix
const pkHref = isPk ? p : isUr ? '/pk' + p.slice(3) : '/pk' + (p === '/' ? '' : p);
const isEn = lang === 'en';
---
<div class="lang-switch">
  <a href={pkHref} class:list={['lang-switch__btn', { active: !isEn }]} data-lang="pk">
    <img src="https://flagcdn.com/w20/pk.png" width="18" height="12" alt="Pakistan" class="lang-switch__flag-img" /><span class="lang-switch__code">PK</span>
  </a>
  <a href={enHref} class:list={['lang-switch__btn', { active: isEn }]} data-lang="en">
    <span class="lang-switch__flag">🌐</span><span class="lang-switch__code">EN</span>
  </a>
</div>
<script is:inline>
  document.querySelectorAll('.lang-switch__btn').forEach(function(b) {
    b.addEventListener('click', function() {
      var lang = b.getAttribute('data-lang');
      localStorage.setItem('ilaaj-lang-manual', lang);
      document.cookie = 'ilaaj-lang-manual=' + lang + ';path=/;max-age=31536000;SameSite=Lax';
    });
  });
</script>
